{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "types": ["node"]
  },
  "include": [
    "helpers/**/*.ts",
    "tests/**/*.ts",
    "api/**/*.ts",
    "factories/**/*.ts",
    "schemas/**/*.ts",
    "playwright.config.ts"
  ]
}
