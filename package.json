{
  "name": "playwright-api-framework",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:clean": "rimraf allure-results test-results && playwright test",
    "report": "allure serve allure-results",
    "report:generate": "allure generate allure-results -o allure-report --clean",
    "report:open": "allure open allure-report",
    "report:serve": "npx http-server allure-report -p 9000 -o",
    "report:clean": "rimraf allure-report",
    "clean": "rimraf allure-results test-results allure-report playwright-report",
    "ci:test": "playwright test",
    "ci:report": "allure generate allure-results -o allure-report --clean",
    "ci:all": "npm run clean && npm run ci:test && npm run ci:report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "allure-commandline": "^2.37.0",
    "allure-playwright": "^3.7.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.1",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
